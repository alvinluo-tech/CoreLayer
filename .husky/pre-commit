pnpm typecheck

echo "Checking Rust formatting..."
cargo fmt --manifest-path frontend/src-tauri/Cargo.toml -- --check || {
  echo "Rust files not formatted. Run: cargo fmt --manifest-path frontend/src-tauri/Cargo.toml"
  exit 1
}

echo "Running Rust clippy..."
cargo clippy --manifest-path frontend/src-tauri/Cargo.toml --all-targets -- -D warnings || {
  echo "Rust clippy check failed. Please fix warnings/errors before committing."
  exit 1
}

npx lint-staged
