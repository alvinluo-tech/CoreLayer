{
  "name": "daemon",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "clean": "rm -rf dist node_modules",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.66",
    "@discordjs/opus": "^0.10.0",
    "@hono/node-server": "^1.14.0",
    "@jarvis/execution-environment": "workspace:*",
    "@jarvis/mcp-client": "workspace:*",
    "@jarvis/model-gateway": "workspace:*",
    "@jarvis/permission-guard": "workspace:*",
    "@jarvis/runtime-core": "workspace:*",
    "@jarvis/runtime-protocol": "workspace:*",
    "@jarvis/tool-registry": "workspace:*",
    "@jarvis/types": "workspace:*",
    "@supabase/supabase-js": "^2.106.2",
    "@types/pg": "^8.20.0",
    "ai": "^6.0.192",
    "better-sqlite3": "^11.7.0",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.38.0",
    "groq-sdk": "^1.2.1",
    "hono": "^4.7.0",
    "pg": "^8.21.0",
    "prism-media": "^1.3.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.10",
    "@types/better-sqlite3": "^7.6.0",
    "@vitest/coverage-v8": "^2.1.9",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
