{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "assistant"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-current-monitor",
    "core:window:allow-outer-size",
    "core:window:allow-outer-position",
    "core:window:allow-set-decorations",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-unminimize",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:webview:default",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-webview-show",
    "core:webview:allow-webview-hide",

    "app:allow-send_message",
    "app:allow-health_check",
    "app:allow-get_health",
    "app:allow-list_conversations",
    "app:allow-create_conversation",
    "app:allow-get_conversation",
    "app:allow-delete_conversation",
    "app:allow-update_conversation",
    "app:allow-send_conversation_message",
    "app:allow-query_tasks",
    "app:allow-create_task",
    "app:allow-update_task",
    "app:allow-delete_task",
    "app:allow-get_reading_list",
    "app:allow-add_article",
    "app:allow-update_reading_status",
    "app:allow-get_daily_summary",
    "app:allow-get_weekly_stats",
    "app:allow-get_voice_status",
    "app:allow-get_daemon_url_command",
    "app:allow-list_mcp_servers",
    "app:allow-list_mcp_tools",
    "app:allow-list_mcp_resources",
    "app:allow-list_mcp_prompts",
    "app:allow-list_all_tools",
    "app:allow-get_tool",
    "app:allow-get_tool_call_logs",
    "app:allow-list_model_profiles",
    "app:allow-get_provider_configs",
    "app:allow-list_provider_presets",
    "app:allow-get_routing_rules",
    "app:allow-get_active_model",
    "app:allow-get_settings",
    "app:allow-get_db_stats",
    "app:allow-daemon_status",
    "app:allow-start_daemon",
    "app:allow-stop_daemon",
    "app:allow-restart_daemon",

    "app:allow-connect_mcp_server",
    "app:allow-disconnect_mcp_server",
    "app:allow-update_storage_mode",
    "app:allow-update_provider_config",
    "app:allow-add_provider",
    "app:allow-remove_provider",
    "app:allow-discover_models",
    "app:allow-test_provider_connection",
    "app:allow-update_routing_rules",
    "app:allow-set_active_model",
    "app:allow-upsert_model_profile",
    "app:allow-delete_model_profile",
    "app:allow-db_manager_list_tables",
    "app:allow-db_manager_get_table_rows",
    "app:allow-db_manager_delete_row",
    "app:allow-db_manager_clear_table",
    "app:allow-db_config_get",
    "app:allow-db_config_set",
    "app:allow-db_config_test",
    "app:allow-db_config_migrate"
  ]
}
